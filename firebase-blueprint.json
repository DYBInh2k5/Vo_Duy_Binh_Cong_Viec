{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "Portfolio work item",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "tagline": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "tech": { "type": "array", "items": { "type": "string" } },
        "image": { "type": "string" },
        "link": { "type": "string" },
        "color": { "type": "string" },
        "order": { "type": "number" }
      },
      "required": ["title", "category", "image"]
    },
    "Experience": {
      "title": "Work Experience",
      "description": "Professional history item",
      "type": "object",
      "properties": {
        "company": { "type": "string" },
        "role": { "type": "string" },
        "period": { "type": "string" },
        "description": { "type": "string" },
        "color": { "type": "string" },
        "order": { "type": "number" }
      },
      "required": ["company", "role", "period"]
    },
    "BlogPost": {
      "title": "Blog Post",
      "description": "Article in markdown",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "excerpt": { "type": "string" },
        "content": { "type": "string" },
        "date": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "image": { "type": "string" },
        "published": { "type": "boolean" }
      },
      "required": ["title", "content", "date"]
    },
    "ContactMessage": {
      "title": "Contact Message",
      "description": "Message from the contact form",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "subject": { "type": "string" },
        "message": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "message"]
    },
    "GuestbookEntry": {
      "title": "Guestbook Entry",
      "description": "Public message from guest",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userPhoto": { "type": "string" },
        "message": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "userName", "message", "timestamp"]
    },
    "CVGeneration": {
      "title": "CV Generation",
      "description": "Bespoke CV configurations synced for recruiter insights",
      "type": "object",
      "properties": {
        "focus": { "type": "string" },
        "themeTitle": { "type": "string" },
        "philosophyStatement": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["focus", "themeTitle", "philosophyStatement", "timestamp"]
    },
    "LabQuery": {
      "title": "Lab Query",
      "description": "Database queries and interactions stored dynamically",
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "query": { "type": "string" },
        "response": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "query", "response", "timestamp"]
    },
    "SystemLog": {
      "title": "System Log",
      "description": "Technical study or industry evolution trend log entry",
      "type": "object",
      "properties": {
        "category": { "type": "string" },
        "title": { "type": "string" },
        "desc": { "type": "string" },
        "date": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["category", "title", "desc", "date", "timestamp"]
    },
    "WorkspaceBlueprint": {
      "title": "Workspace Blueprint Task",
      "description": "Custom task specifications injected into the automation pipeline",
      "type": "object",
      "properties": {
        "task": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["task", "timestamp"]
    }
  },
  "firestore": {
    "/system_logs/{logId}": {
      "schema": "SystemLog",
      "description": "System-wide protocol, study, and tech trend logs"
    },
    "/workspace_blueprints/{blueprintId}": {
      "schema": "WorkspaceBlueprint",
      "description": "Injected custom automation task specifications"
    },
    "/cv_generations/{id}": {
      "schema": "CVGeneration",
      "description": "Logs of generated custom resumes"
    },
    "/lab_queries/{id}": {
      "schema": "LabQuery",
      "description": "Inquiries processed on grounding and caching nodes"
    },
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Collection of portfolio projects"
    },
    "/experience/{experienceId}": {
      "schema": "Experience",
      "description": "Professional history"
    },
    "/blogs/{blogId}": {
      "schema": "BlogPost",
      "description": "Blog articles"
    },
    "/contacts/{contactId}": {
      "schema": "ContactMessage",
      "description": "User messages from contact form"
    },
    "/guestbook/{entryId}": {
      "schema": "GuestbookEntry",
      "description": "Public messages from visiting users"
    },
    "/admins/{uid}": {
      "schema": { "type": "object", "properties": { "role": { "type": "string" } } },
      "description": "Admin users"
    }
  }
}
