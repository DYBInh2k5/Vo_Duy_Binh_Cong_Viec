{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "Portfolio work item",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "tagline": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "tech": { "type": "array", "items": { "type": "string" } },
        "image": { "type": "string" },
        "link": { "type": "string" },
        "color": { "type": "string" },
        "order": { "type": "number" }
      },
      "required": ["title", "category", "image"]
    },
    "Experience": {
      "title": "Work Experience",
      "description": "Professional history item",
      "type": "object",
      "properties": {
        "company": { "type": "string" },
        "role": { "type": "string" },
        "period": { "type": "string" },
        "description": { "type": "string" },
        "color": { "type": "string" },
        "order": { "type": "number" }
      },
      "required": ["company", "role", "period"]
    },
    "BlogPost": {
      "title": "Blog Post",
      "description": "Article in markdown",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "excerpt": { "type": "string" },
        "content": { "type": "string" },
        "date": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "image": { "type": "string" },
        "published": { "type": "boolean" }
      },
      "required": ["title", "content", "date"]
    },
    "ContactMessage": {
      "title": "Contact Message",
      "description": "Message from the contact form",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "subject": { "type": "string" },
        "message": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "message"]
    },
    "GuestbookEntry": {
      "title": "Guestbook Entry",
      "description": "Public message from guest",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userPhoto": { "type": "string" },
        "message": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "userName", "message", "timestamp"]
    }
  },
  "firestore": {
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Collection of portfolio projects"
    },
    "/experience/{experienceId}": {
      "schema": "Experience",
      "description": "Professional history"
    },
    "/blogs/{blogId}": {
      "schema": "BlogPost",
      "description": "Blog articles"
    },
    "/contacts/{contactId}": {
      "schema": "ContactMessage",
      "description": "User messages from contact form"
    },
    "/guestbook/{entryId}": {
      "schema": "GuestbookEntry",
      "description": "Public messages from visiting users"
    },
    "/admins/{uid}": {
      "schema": { "type": "object", "properties": { "role": { "type": "string" } } },
      "description": "Admin users"
    }
  }
}
