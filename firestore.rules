rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        (request.auth.token.email == "binhvo20055@gmail.com" && request.auth.token.email_verified == true)
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Blueprints ---

    function isValidProject(data) {
      return data.keys().hasAll(['title', 'category', 'image']) &&
             data.title is string && data.title.size() <= 200 &&
             data.category is string &&
             data.image is string;
    }

    function isValidBlogPost(data) {
      return data.keys().hasAll(['title', 'content', 'date']) &&
             data.title is string && data.title.size() <= 300 &&
             data.content is string && data.content.size() <= 50000 &&
             data.date is string;
    }

    function isValidContactMessage(data) {
      return data.keys().hasAll(['name', 'email', 'message']) &&
             data.name is string && data.name.size() <= 100 &&
             data.email is string && data.email.size() <= 100 &&
             data.message is string && data.message.size() <= 2000;
    }

    function isValidGuestbookEntry(data) {
      return data.keys().hasAll(['userId', 'userName', 'message', 'timestamp']) &&
             data.userId == request.auth.uid &&
             data.userName is string && data.userName.size() <= 100 &&
             data.message is string && data.message.size() <= 500 &&
             data.timestamp is timestamp;
    }

    // --- Collections ---

    match /admins/{uid} {
      allow read: if isSignedIn();
      allow write: if false; // Only manageable via Firebase Console or special script
    }

    match /projects/{projectId} {
      allow read: if true;
      allow write: if isAdmin() && isValidId(projectId) && isValidProject(incoming());
    }

    match /experience/{experienceId} {
      allow read: if true;
      allow write: if isAdmin() && isValidId(experienceId);
    }

    match /blogs/{blogId} {
      allow read: if true;
      allow write: if isAdmin() && isValidId(blogId) && isValidBlogPost(incoming());
    }

    match /contacts/{contactId} {
      allow create: if isValidId(contactId) && isValidContactMessage(incoming());
      allow read, update, delete: if isAdmin();
    }

    match /guestbook/{entryId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidId(entryId) && isValidGuestbookEntry(incoming());
      allow update, delete: if isAdmin() || isOwner(existing().userId);
    }
  }
}
