rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        (request.auth.token.email == "binhvo20055@gmail.com" && request.auth.token.email_verified == true)
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Blueprints ---

    function isValidProject(data) {
      return data.keys().hasAll(['title', 'category', 'image']) &&
             data.title is string && data.title.size() <= 200 &&
             data.category is string &&
             data.image is string;
    }

    function isValidBlogPost(data) {
      return data.keys().hasAll(['title', 'content', 'date']) &&
             data.title is string && data.title.size() <= 300 &&
             data.content is string && data.content.size() <= 50000 &&
             data.date is string;
    }

    function isValidContactMessage(data) {
      return data.keys().hasAll(['name', 'email', 'message']) &&
             data.name is string && data.name.size() <= 100 &&
             data.email is string && data.email.size() <= 100 &&
             data.message is string && data.message.size() <= 2000;
    }

    function isValidGuestbookEntry(data) {
      return data.keys().hasAll(['userId', 'userName', 'message', 'timestamp']) &&
             data.userId == request.auth.uid &&
             data.userName is string && data.userName.size() <= 100 &&
             data.message is string && data.message.size() <= 500 &&
             data.timestamp is timestamp;
    }

    function isValidCVGeneration(data) {
      return data.keys().hasAll(['focus', 'themeTitle', 'philosophyStatement', 'timestamp']) &&
             data.focus is string && data.focus.size() <= 1000 &&
             data.themeTitle is string && data.themeTitle.size() <= 300 &&
             data.philosophyStatement is string && data.philosophyStatement.size() <= 2000 &&
             data.timestamp is timestamp;
    }

    function isValidLabQuery(data) {
      return data.keys().hasAll(['type', 'query', 'response', 'timestamp']) &&
             data.type is string && data.type.size() <= 100 &&
             data.query is string && data.query.size() <= 2000 &&
             data.response is string && data.response.size() <= 20000 &&
             data.timestamp is timestamp;
    }

    function isValidSystemLog(data) {
      return data.keys().hasAll(['category', 'title', 'desc', 'date', 'timestamp']) &&
             data.category is string && (data.category == 'PROTO' || data.category == 'TREND') &&
             data.title is string && data.title.size() <= 300 &&
             data.desc is string && data.desc.size() <= 5000 &&
             data.date is string &&
             data.timestamp is timestamp;
    }

    function isValidWorkspaceBlueprint(data) {
      return data.keys().hasAll(['task', 'timestamp']) &&
             data.task is string && data.task.size() <= 300 &&
             data.timestamp is timestamp;
    }

    function isValidPageView(data) {
      return data.keys().hasAll(['pagePath', 'pageTitle', 'timestamp', 'sessionId', 'referrer']) &&
             data.keys().size() == 5 &&
             data.pagePath is string && data.pagePath.size() <= 600 &&
             data.pageTitle is string && data.pageTitle.size() <= 600 &&
             data.timestamp is timestamp &&
             data.sessionId is string && data.sessionId.size() <= 256 &&
             data.referrer is string && data.referrer.size() <= 3000;
    }

    // --- Collections ---

    match /system_logs/{logId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidId(logId) && isValidSystemLog(incoming());
      allow update, delete: if isAdmin();
    }

    match /workspace_blueprints/{blueprintId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidId(blueprintId) && isValidWorkspaceBlueprint(incoming());
      allow update, delete: if isAdmin();
    }

    match /cv_generations/{id} {
      allow create: if isValidId(id) && isValidCVGeneration(incoming());
      allow read, update, delete: if isAdmin();
    }

    match /lab_queries/{id} {
      allow create: if isValidId(id) && isValidLabQuery(incoming());
      allow read, update, delete: if isAdmin();
    }

    match /admins/{uid} {
      allow read: if isSignedIn();
      allow write: if false; // Only manageable via Firebase Console or special script
    }

    match /projects/{projectId} {
      allow read: if true;
      allow write: if isAdmin() && isValidId(projectId) && isValidProject(incoming());
    }

    match /experience/{experienceId} {
      allow read: if true;
      allow write: if isAdmin() && isValidId(experienceId);
    }

    match /blogs/{blogId} {
      allow read: if true;
      allow write: if isAdmin() && isValidId(blogId) && isValidBlogPost(incoming());
    }

    match /contacts/{contactId} {
      allow create: if isValidId(contactId) && isValidContactMessage(incoming());
      allow read, update, delete: if isAdmin();
    }

    match /page_views/{viewId} {
      allow create: if isValidId(viewId) && isValidPageView(incoming());
      allow read, update, delete: if isAdmin();
    }

    match /guestbook/{entryId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidId(entryId) && isValidGuestbookEntry(incoming());
      allow update, delete: if isAdmin() || isOwner(existing().userId);
    }
  }
}
